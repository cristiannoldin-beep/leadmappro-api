# App
NODE_ENV=production
PORT=3333
HOST=0.0.0.0

# Banco de dados (PostgreSQL 16 no Coolify)
DATABASE_URL=postgresql://leadmappro:SENHA@leadmappro-postgres:5432/leadmappro_production

# Auth
JWT_SECRET=gerar-com-openssl-rand-base64-64

# CORS (separar por vírgula para múltiplos origins)
ALLOWED_ORIGINS=https://app.leadmappro.com.br

# Cron (substitui pg_cron do Supabase)
CRON_SECRET=gerar-com-openssl-rand-base64-32

# Criptografia de credenciais (compatível com ENCRYPTION_KEY do Supabase)
ENCRYPTION_KEY=mesma-chave-do-supabase-ou-gerar-nova-base64-32

# Cloudflare R2
R2_ENDPOINT=https://1663f4ef186225980e35ac7b460c15b3.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=leadmappro-assets
R2_PUBLIC_URL=https://assets.leadmappro.com.br

# WhatsApp (UazAPI)
WEBHOOK_SECRET=

# Meta (WhatsApp Business API)
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# IA
OPENAI_API_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Stripe (opcional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Asaas (opcional)
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
